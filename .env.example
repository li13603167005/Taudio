# Taudio local server
HOST=127.0.0.1
PORT=8080
REALTIME_STRICT=1
TAUDIO_TIMEZONE=Asia/Shanghai

# Claude CLI adapter
# Set to 1 only after the local `claude` command is available.
BRAIN_PROVIDER=local
TAUDIO_USE_CLAUDE=0
CLAUDE_COMMAND=claude
CLAUDE_TIMEOUT_MS=25000

# DeepSeek brain provider
# Set BRAIN_PROVIDER=deepseek after adding a key.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=500
DEEPSEEK_TIMEOUT_MS=20000

# NeteaseCloudMusicApi
# Example: http://127.0.0.1:3000
MUSIC_PROVIDER=netease-enhanced
NETEASE_API_BASE=
NETEASE_LEVEL=exhigh
# Optional but recommended for VIP/full-song playback. Keep this private.
# Example: MUSIC_U=...; __csrf=...; NMTID=...
NETEASE_COOKIE=

# Text to speech
# browser = free speechSynthesis on the phone/desktop browser.
# none = show DJ text but do not speak it.
TTS_PROVIDER=browser

# OpenWeather
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Shanghai
OPENWEATHER_LAT=
OPENWEATHER_LON=
OPENWEATHER_UNITS=metric
OPENWEATHER_LANG=zh_cn

# Feishu calendar
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CALENDAR_ID=primary

# Local fallback context
TAUDIO_WEATHER=室内收听，天气未知，默认清爽电台氛围
TAUDIO_NEXT_EVENT=暂无即将开始的日程

# Optional: set this if your machine needs a local HTTP proxy for overseas APIs.
# Common local proxy ports are 7890, 7897, 10809, or 10811 depending on your client.
# HTTPS_PROXY=http://127.0.0.1:7890
